\newlabel{subsec:qpu}{{\mbox  {IV-C}}{3}{}{subsection.4.3}{}}
\newlabel{subsec:qpu@cref}{{[subsection][3][4]\mbox  {IV-C}}{[1][3][]3}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Study~1: Hybrid solver benchmark (10--1{,}000 patches).} \emph  {Left (Runtime):} Gurobi CQM scales 0.006--3.8\,s; D-Wave CQM hybrid $\approx $5--11\,s (QPU $\leq $1.3\% of wall time); BQM hybrid 3--344\,s; Gurobi BQM times out ($\geq $300\,s) at every scale. \emph  {Middle (Absolute Gap):} Solid = raw objectives; open/dashed = healed (\cref  {sec:healing}). CQM gap below $10^{-2}$ at $n{=}25$--$50$ after healing; raw inflation 2.9--3.4 at $n{\geq }200$. Healed CQM gap ${\sim }0.1$--$0.2$ at scale; healed BQM gap ${>}0.1$ everywhere. \emph  {Right (Gap + Violations):} Violation count bars (secondary axis) show actual patches with $Y_{p,c}{>}0.5$ for more than one crop (post-processed, not the built-in validator). Both solvers accumulate violations at every scale: BQM 9--11 at $n{\leq }25$, rising to 100 at $n{=}100$ and all $n$ patches at $n{\geq }200$; CQM 2--12 at $n{\leq }50$, escalating similarly. The validator counter reports zero at $n{\geq }50$, masking this systematic infeasibility. Gurobi CQM dominates on all metrics.}}{4}{}\protected@file@percent }
\newlabel{fig:hybrid_solver_performance}{{1}{4}{}{figure.1}{}}
\newlabel{fig:hybrid_solver_performance@cref}{{[figure][1][]1}{[1][3][]4}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {IV}{\ignorespaces QPU time vs.\ classical embedding time for Multilevel(10) decomposition. Embedding constitutes 76--86\% of total time; QPU remains 1.2--3.1\% across all scales.}}{4}{}\protected@file@percent }
\newlabel{tab:qpu_scaling}{{IV}{4}{}{table.4}{}}
\newlabel{tab:qpu_scaling@cref}{{[table][4][]IV}{[1][4][]4}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces Solution quality at the 1{,}000-farm scale. Gap = $|Z_{\text  {method}} - Z^{\star }_{\text  {Gurobi}}|$. ``(h)'' rows show healed objectives; for methods with zero violations healed $=$ raw. Gurobi decomposed methods are marked *; CQMFirst* has 3 food-group violations; Multilevel(10)* and Coordinated* each incur 5.}}{4}{}\protected@file@percent }
\newlabel{tab:quality_1000}{{V}{4}{}{table.5}{}}
\newlabel{tab:quality_1000@cref}{{[table][5][]V}{[1][4][]4}{}{}{}}
